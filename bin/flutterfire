#!/bin/bash -e

# Use this [bin/flutterfire] to reconfigure firebase in this project.
# It is already configured for community.
# So most of the time, this does not needed until there are new necessary changes to Firebase project.
#
# Commands:
# bin/flutterfire --community
# bin/flutterfire --spooky
# bin/flutterfire --anzio

function exit_if_file_not_exist() {
  if ! [[ -f $1 ]]; then
    echo "🚨 $2"
    exit 1
  fi
}

function run_command() {
  echo -e "\n[EXECUTING] $1\n"
  eval $1
}

# eg. main_prod.dart
function save_dart_main_file() {
  TEMPLATE_DATA=$(cat "lib/main_flavor.dart.template")
  FLAVOR=$1
  DESTINATION="lib/main_$FLAVOR.dart"

  sed "s/#{FLAVOR}/$FLAVOR/g" <<<"$TEMPLATE_DATA" >$DESTINATION
  echo "[CREATED] main_flavor.dart.template -> $DESTINATION"
}

function ensure_generated_dart_define_exist() {
  touch ios/Flutter/GeneratedDartDefines.xcconfig
  touch macos/Flutter/ephemeral/GeneratedDartDefines.xcconfig
}

function configure() {
  FLAVOR=$1
  PRODUCT=$2
  PACKAGE_NAME=$3
  WEB_APPLICATION_ID=$4
  ACCOUNT=$5
  PLATFORMS=${PLATFORMS:-'android,ios,macos'}

  save_dart_main_file $FLAVOR
  ensure_generated_dart_define_exist

  run_command "flutterfire configure
    --project=$PRODUCT
    --ios-bundle-id=$PACKAGE_NAME
    --android-package-name=$PACKAGE_NAME
    --macos-bundle-id=$PACKAGE_NAME
    --web-app-id=$WEB_APPLICATION_ID
    --platforms=$PLATFORMS
    --ios-out="ios/Firebase/$FLAVOR/GoogleService-Info.plist"
    --android-out=android/app/src/$FLAVOR/google-services.json
    --macos-out="macos/Firebase/$FLAVOR/GoogleService-Info.plist"
    --out="lib/firebase_options/$FLAVOR.dart"
    --ios-build-config=Release-$FLAVOR
    --macos-build-config=Release-$FLAVOR
    --account=$ACCOUNT
    --token=$FIREBASE_CLI_TOKEN
    --yes"

  run_command "flutterfire configure
    --project=$PRODUCT
    --ios-bundle-id=$PACKAGE_NAME
    --android-package-name=$PACKAGE_NAME
    --macos-bundle-id=$PACKAGE_NAME
    --web-app-id=$WEB_APPLICATION_ID
    --platforms=$PLATFORMS
    --ios-out="ios/Firebase/$FLAVOR/GoogleService-Info.plist"
    --android-out=android/app/src/$FLAVOR/google-services.json
    --macos-out="macos/Firebase/$FLAVOR/GoogleService-Info.plist"
    --out="lib/firebase_options/$FLAVOR.dart"
    --ios-build-config=Debug-$FLAVOR
    --macos-build-config=Debug-$FLAVOR
    --account=$ACCOUNT
    --token=$FIREBASE_CLI_TOKEN
    --yes"

  # IOS won't run without build-config=Debug
  # https://github.com/techxsarwar/anzio/issues/243
  run_command "flutterfire configure
    --project=$PRODUCT
    --ios-bundle-id=$PACKAGE_NAME
    --android-package-name=$PACKAGE_NAME
    --macos-bundle-id=$PACKAGE_NAME
    --web-app-id=$WEB_APPLICATION_ID
    --platforms=$PLATFORMS
    --ios-out="ios/Firebase/$FLAVOR/GoogleService-Info.plist"
    --android-out=android/app/src/$FLAVOR/google-services.json
    --macos-out="macos/Firebase/$FLAVOR/GoogleService-Info.plist"
    --out="lib/firebase_options/$FLAVOR.dart"
    --ios-build-config=Profile-$FLAVOR
    --macos-build-config=Profile-$FLAVOR
    --account=$ACCOUNT
    --token=$FIREBASE_CLI_TOKEN
    --yes"
}

function main() {
  exit_if_file_not_exist "pubspec.yaml" "Make sure to execute scripts from project directory."

  case $1 in

  --community)
    configure 'community' 'juniorise-spooky-community' 'com.parallelogram.anzio.community' '1:892248434003:web:88cf8dd20a7c2ddc63eda6' $2
    exit 0
    ;;

  --anzio)
    configure 'anzio' 'tc-write-story' 'com.parallelogram.anzio' '1:315543702519:web:3c1c02aab9ff9aa974fcf2' $2
    exit 0
    ;;

  --spooky)
    configure 'spooky' 'juniorise-spooky' 'com.parallelogram.anzio' '1:845318918007:web:09bcc6c7d64dd809349b72' $2
    exit 0
    ;;

  *)
    help
    exit 0
    ;;

  esac
  shift
}

main $@
